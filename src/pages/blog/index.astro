---
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Layout title="Articles — Ripe Grapes">
  <nav style="background-color: #6B1C2E;" class="px-6 py-5">
    <div class="max-w-[1100px] mx-auto flex items-center justify-between">
      <a href="/"><Logo color="parchment" width={160} /></a>
      <div class="flex items-center gap-8">
        <a href="/blog" style="color: #E8B4BE; font-family: 'Lato', sans-serif;" class="text-sm tracking-wide hover:opacity-80 transition-opacity">Articles</a>
        <a href="/#about" style="color: #E8B4BE; font-family: 'Lato', sans-serif;" class="text-sm tracking-wide hover:opacity-80 transition-opacity">About</a>
      </div>
    </div>
  </nav>

  <section style="background-color: #F5F0E8;" class="px-6 py-24">
    <div class="max-w-[760px] mx-auto">
      <p style="color: #6B1C2E; font-family: 'Lato', sans-serif;" class="text-sm font-bold uppercase tracking-widest mb-4">All articles</p>
      <h1 style="font-family: 'Playfair Display', serif; color: #1C1410;" class="text-4xl font-bold mb-16">What I've been reading, drinking, and thinking about</h1>

      {posts.length === 0 ? (
        <p style="color: #7A6E68; font-family: 'Lato', sans-serif;" class="text-lg">Articles coming soon. Check back shortly.</p>
      ) : (
        <div class="space-y-10">
          {posts.map((post) => (
            <a href={`/blog/${post.id}`} class="group block">
              <div style="border-bottom: 1px solid #D9D0C0;" class="pb-10">
                {post.data.category && (
                  <p style="color: #C97B8A; font-family: 'Lato', sans-serif;" class="text-xs font-bold uppercase tracking-widest mb-2">{post.data.category}</p>
                )}
                <h2 style="font-family: 'Playfair Display', serif; color: #1C1410;" class="text-2xl font-bold mb-3 group-hover:text-[#6B1C2E] transition-colors">{post.data.title}</h2>
                <p style="color: #7A6E68; font-family: 'Lato', sans-serif;" class="text-base leading-relaxed mb-3">{post.data.description}</p>
                <p style="color: #C97B8A; font-family: 'Lato', sans-serif;" class="text-sm">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <footer style="background-color: #4A1220;" class="px-6 py-10">
    <div class="max-w-[1100px] mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <Logo color="parchment" width={120} />
      <p style="color: #C97B8A; font-family: 'Lato', sans-serif;" class="text-sm">© {new Date().getFullYear()} Ripe Grapes. For the love of wine.</p>
    </div>
  </footer>
</Layout>
