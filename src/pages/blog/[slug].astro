---
import Layout from '../../layouts/Layout.astro';
import Logo from '../../components/Logo.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} — Ripe Grapes`} description={post.data.description}>
  <nav style="background-color: #6B1C2E;" class="px-6 py-5">
    <div class="max-w-[1100px] mx-auto flex items-center justify-between">
      <a href="/"><Logo color="parchment" width={160} /></a>
      <div class="flex items-center gap-8">
        <a href="/blog" style="color: #E8B4BE; font-family: 'Lato', sans-serif;" class="text-sm tracking-wide hover:opacity-80 transition-opacity">Articles</a>
        <a href="/#about" style="color: #E8B4BE; font-family: 'Lato', sans-serif;" class="text-sm tracking-wide hover:opacity-80 transition-opacity">About</a>
      </div>
    </div>
  </nav>

  <article style="background-color: #F5F0E8;" class="px-6 py-24">
    <div class="max-w-[680px] mx-auto">
      {post.data.category && (
        <p style="color: #C97B8A; font-family: 'Lato', sans-serif;" class="text-xs font-bold uppercase tracking-widest mb-4">{post.data.category}</p>
      )}
      <h1 style="font-family: 'Playfair Display', serif; color: #1C1410;" class="text-4xl md:text-5xl font-bold leading-tight mb-6">{post.data.title}</h1>
      <p style="color: #7A6E68; font-family: 'Lato', sans-serif;" class="text-sm mb-12">
        {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </p>
      <div class="prose-ripe" style="font-family: 'Lato', sans-serif; color: #1C1410; font-size: 1.125rem; line-height: 1.8;">
        <Content />
      </div>
      <div class="mt-16 pt-8" style="border-top: 1px solid #D9D0C0;">
        <a href="/blog" style="color: #6B1C2E; font-family: 'Lato', sans-serif;" class="font-bold hover:opacity-70 transition-opacity">← Back to all articles</a>
      </div>
    </div>
  </article>

  <footer style="background-color: #4A1220;" class="px-6 py-10">
    <div class="max-w-[1100px] mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <Logo color="parchment" width={120} />
      <p style="color: #C97B8A; font-family: 'Lato', sans-serif;" class="text-sm">© {new Date().getFullYear()} Ripe Grapes. For the love of wine.</p>
    </div>
  </footer>
</Layout>
